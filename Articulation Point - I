Solution : 

class Solution {
    // Function to return Breadth First Traversal of given graph.
    int times = 0;
    void dfs(int u,int parent,int[] disc,int[] low,boolean[] visited,
        boolean[] aps,ArrayList<ArrayList<Integer>> adj){
        disc[u]=low[u]=times++;
        visited[u]=true;
        
        int children = 0;
        for(int v : adj.get(u)){
            if(v==parent) continue;
            if(!visited[v]){
                children++;
                dfs(v,u,disc,low,visited,aps,adj);
                low[u] = Math.min(low[u],low[v]);
                
                if(parent!=-1 && low[v]>=disc[u]){
                    aps[u]=true;
                }
            }
            else{
                low[u] = Math.min(low[u],disc[v]);
            }
        }
        if(parent==-1 && children > 1)
            aps[u] = true;
    }

    public ArrayList<Integer> articulationPoints(int V,
        ArrayList<ArrayList<Integer>> adj) {
        // Code here
        int len = adj.size();
        int[] disc = new int[len];
        int[] low = new int[len];
        boolean[] visited = new boolean[len];
        boolean[] aps = new boolean[len];
        for(int i=0;i<len;i++){
            if(!visited[i])
                dfs(i,-1,disc,low,visited,aps,adj);
        }
        
        ArrayList<Integer> res=new ArrayList<>();
        for(int i=0;i<len;i++){
            if(aps[i]) res.add(i);
        }
        if(res.size()==0)
            res.add(-1);
        return res;
    }
}
